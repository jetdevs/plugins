{
  "description": "Auto-launch codex spec review after create-specs completes",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/codex-spec-review.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
